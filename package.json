    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.26",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.7.0",
    "jsdom": "^25.0.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tailwindcss": "^3.4.19",
