{
  "name": "zimbabwe-maids-centre",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node --env-file=.env.local scripts/migrate.mjs",
    "db:setup": "node test-db/setup.mjs"
  },
  "dependencies": {
