VITE_SUPPORT_PHONE=+263785458828
VITE_SUPPORT_WHATSAPP=+263773022135

# Feature Flags
VITE_ENABLE_PAYNOW=true
VITE_ENABLE_ECOCASH=true
VITE_ENABLE_WHATSAPP_BOT=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
